                id: 30,
                type: 'choice',
                q: '예수님이 요단강 세례 이후 공생애 시작에 앞서, 광야에서 40일 동안 주린 상태에서 누구에게 세 가지 질문으로 시험을 받으셨나요?',
                a: '사탄 (마귀)',
                options: ['바리새인', '헤롯 왕', '사탄 (마귀)', '빌라도'],
                hint: '기록된 성경 말씀인 "사람이 떡으로만 살 것이 아니요" 등으로 물리치신 정체예요.'
            }
        ];

        let state = {
            questions: [],
            currentIndex: 0,
            score: 0,
            gameState: 'start', // 'start' | 'playing' | 'feedback' | 'finished'
            userInput: '',
            feedback: {
                isCorrect: false,
                message: ''
            }
        };

        // Fisher-Yates shuffle algorithm
        function shuffleQuestions(array) {
            const arr = [...array];
            for (let i = arr.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [arr[i], arr[j]] = [arr[j], arr[i]];
            }
            return arr;
        }

        // Clip board share helper
        function copyToClipboard(text) {
            const textarea = document.createElement('textarea');
            textarea.value = text;
            textarea.style.position = 'fixed'; // Prevent scrolling to bottom
            document.body.appendChild(textarea);
            textarea.select();
            try {
                document.execCommand('copy');
                showModal('📋 복사 완료!', '결과 메시지가 클립force 복사되었어요!\n카카오톡 단톡방이나 문자에 붙여넣기(Ctrl+V)해서 친구들에게 공유해 보세요! 😉', '🎉');
            } catch (err) {
                showModal('⚠️ 복사 실패', '복사하기가 지원되지 않는 환경입니다. 직접 결과를 알려주세요!', '😢');
            }
            document.body.removeChild(textarea);
        }

        function shareResults() {
            let ratingTitle = '';
            if (state.score >= 26) {
                ratingTitle = '👑 영광의 성경 박사님!';
            } else if (state.score >= 18) {
                ratingTitle = '👍 우수한 믿음의 용사!';
            } else {
                ratingTitle = '🌱 무럭무럭 새싹 친구!';
            }

            const text = `📖 [주일학교 성경 골든벨] 도전 완료! 🏆\n\n✨ 나의 성경 지식 점수는?\n👉 ${state.score} / 30점 (${ratingTitle})\n\n우와! 너도 성경 골든벨에 도전해서 성경 박사가 되어볼래? 하나님의 말씀은 내 발의 등이요 내 길의 빛이란다! 🌟`;
            copyToClipboard(text);
        }

        function initApp() {
            state.questions = shuffleQuestions(quizQuestions);
            state.currentIndex = 0;
            state.score = 0;
            state.gameState = 'start';
            state.userInput = '';
            render();
        }

        function startQuiz() {
            state.gameState = 'playing';
            render();
        }

        function submitAnswer(chosenAnswer) {
            const currentQ = state.questions[state.currentIndex];
            let rawUserAnswer = chosenAnswer !== undefined ? chosenAnswer : state.userInput;
            
            if (!rawUserAnswer || rawUserAnswer.trim() === '') {
                showModal('⚠️ 알림', '정답을 입력하거나 선택해 주세요!', 'ℹ️');
                return;
            }

            // Normalization: Lowercase, space strip, special character strip
            const normalize = (str) => {
                return str.replace(/\s+/g, '') // 공백 제거
                          .replace(/[.,\-_~'"]/g, '') // 문장 기호 제거
                          .toLowerCase()
                          .trim();
            };

            const cleanUser = normalize(rawUserAnswer);
            const cleanCorrect = normalize(currentQ.a);

            let isCorrect = cleanUser === cleanCorrect;

            // Check alternative answers
            if (!isCorrect && currentQ.altAnswers) {
                isCorrect = currentQ.altAnswers.some(alt => normalize(alt) === cleanUser || cleanUser.includes(normalize(alt)));
            }

            // Additional checks for specific questions to increase friendliness
            if (!isCorrect) {
                // If the answer is partially included for lenient marking
                if (cleanUser.includes(cleanCorrect) && cleanUser.length <= cleanCorrect.length + 3) {
                    isCorrect = true;
                }
            }

            if (isCorrect) {
                state.score++;
                state.feedback = {
                    isCorrect: true,
                    message: '🎉 참 잘했어요! 정답입니다! 👏'
                };
            } else {
                state.feedback = {
                    isCorrect: false,
                    message: `아쉬워요! 정답은 [ ${currentQ.a} ] 입니다.`
                };
            }

            state.gameState = 'feedback';
            render();
        }

        function nextQuestion() {
            if (state.currentIndex < state.questions.length - 1) {
                state.currentIndex++;
                state.userInput = '';
                state.gameState = 'playing';
            } else {
                state.gameState = 'finished';
            }
            render();
        }

        function showModal(title, text, icon = '💡') {
            document.getElementById('modal-title').innerText = title;
            document.getElementById('modal-body').innerText = text;
            document.getElementById('modal-icon').innerText = icon;
            
            const container = document.getElementById('modal-container');
            const content = document.getElementById('modal-content');
            container.classList.remove('hidden');
            setTimeout(() => {
                content.classList.remove('scale-95');
                content.classList.add('scale-100');
            }, 10);
        }

        function closeModal() {
            const container = document.getElementById('modal-container');
            const content = document.getElementById('modal-content');
            content.classList.remove('scale-100');
            content.classList.add('scale-95');
            setTimeout(() => {
                container.classList.add('hidden');
            }, 150);
        }

        function showHintPopup() {
            const currentQ = state.questions[state.currentIndex];
            showModal('💡 성경 박사님의 힌트', currentQ.hint, '🔎');
        }

        function render() {
            const container = document.getElementById('app');
            
            if (state.gameState === 'start') {
                container.innerHTML = `
                    <div class="bg-white rounded-3xl shadow-2xl p-6 md:p-10 text-center border-t-8 border-yellow-400 slide-up max-w-md mx-auto">
                        <div class="text-6xl mb-4">📖</div>
                        <h1 class="text-3xl md:text-4xl font-extrabold text-blue-600 mb-2 kids-font">주일학교 성경 골든벨</h1>
                        <p class="text-yellow-500 font-bold text-lg mb-6 kids-font">예수님 사랑 성경 30선 퀴즈</p>
                        
                        <div class="bg-blue-50 rounded-2xl p-4 text-left text-sm text-gray-600 mb-8 space-y-2 border border-blue-100">
                            <p class="font-bold text-blue-800 text-center text-base mb-1">🎮 이런 방식으로 진행돼요!</p>
                            <p>✨ <b>단답형 15문제</b>와 <b>객관식 15문제</b>가 골고루 섞여 있어요.</p>
                            <p>✨ 매번 시작할 때마다 문제 순서가 무작위로 바뀌어 나와요.</p>
                            <p>✨ 모를 때는 주저없이 <b>'힌트💡'</b> 버튼을 꾹 누르세요!</p>
                        </div>

                        <button 
                            onclick="startQuiz()"
                            class="w-full bg-yellow-400 hover:bg-yellow-500 active:scale-95 text-blue-900 font-extrabold py-4 rounded-2xl shadow-lg transition duration-200 text-xl kids-font tracking-wider"
                        >
                            출발! 성경 여행 가기 🚀
                        </button>
                    </div>
                `;
                return;
            }

            if (state.gameState === 'finished') {
                let ratingTitle = '';
                let ratingIcon = '';
                let ratingColor = '';
                let encouragement = '';

                if (state.score >= 26) {
                    ratingTitle = '👑 영광의 성경 박사님!';
                    ratingIcon = '🏆';
                    ratingColor = 'text-yellow-500';
                    encouragement = '하나님 말씀의 깊이를 훤히 꿰뚫고 있군요! 믿음 안에서 무럭무럭 자라나 세상을 축복하는 멋진 어린이가 될 거예요! 축하해요! 🎉';
                } else if (state.score >= 18) {
                    ratingTitle = '👍 우수한 믿음의 용사!';
                    ratingIcon = '⭐';
                    ratingColor = 'text-green-500';
                    encouragement = '성경과 정말 친밀한 친구군요! 조금만 더 하면 완벽한 성경 골든벨의 주역이 될 수 있어요. 자랑스러워요! 🥰';
                } else {
                    ratingTitle = '🌱 무럭무럭 새싹 친구!';
                    ratingIcon = '🌱';
                    ratingColor = 'text-blue-500';
                    encouragement = '참 열심히 잘 풀어주었어요! 말씀을 더 자주 가슴에 품다 보면 다음에는 꼭 성경 백 점 박사가 될 거예요! 말씀 일기 파이팅! 💪';
                }

                container.innerHTML = `
                    <div class="bg-white rounded-3xl shadow-2xl p-6 md:p-10 text-center slide-up max-w-md mx-auto border-t-8 border-indigo-500">
                        <div class="text-6xl mb-4">${ratingIcon}</div>
                        <h2 class="text-3xl font-extrabold text-blue-700 mb-2 kids-font">도전 완료!</h2>
                        <p class="text-sm font-bold text-gray-400 mb-6 uppercase tracking-widest">Your Score Card</p>
                        
                        <div class="bg-slate-50 rounded-2xl p-6 mb-6 border border-slate-100">
                            <div class="text-6xl font-black ${ratingColor} mb-2">${state.score} <span class="text-2xl text-gray-400 font-bold">/ 30</span></div>
                            <h3 class="text-xl font-bold text-gray-800 mb-2">${ratingTitle}</h3>
                            <p class="text-gray-600 text-sm leading-relaxed">${encouragement}</p>
                        </div>

                        <div class="flex flex-col gap-3">
                            <button 
                                onclick="shareResults()"
                                class="w-full bg-emerald-500 hover:bg-emerald-600 text-white font-extrabold py-4 rounded-2xl shadow-lg transition active:scale-95 text-lg kids-font tracking-wide"
                            >
                                카카오톡 결과 공유하기 💬
                            </button>
                            <button 
                                onclick="initApp()"
                                class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-4 rounded-2xl shadow-lg transition active:scale-95 text-lg"
                            >
                                새로운 마음으로 다시 풀기 🔄
                            </button>
                        </div>
                    </div>
                `;
                return;
            }

            // 'playing' or 'feedback' state
            const currentQ = state.questions[state.currentIndex];
            const progressPercent = ((state.currentIndex + (state.gameState === 'feedback' ? 1 : 0)) / state.questions.length) * 100;

            let interactionHtml = '';

            if (state.gameState === 'playing') {
                if (currentQ.type === 'choice') {
                    // 객관식 렌더링
                    interactionHtml = `
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3.5 mt-4">
                            ${currentQ.options.map((option, index) => {
                                return `
                                    <button 
                                        onclick="submitAnswer('${option.replace(/'/g, "\\'")}')"
                                        class="p-4 text-left border-2 border-blue-100 rounded-2xl hover:bg-blue-50 hover:border-blue-400 transition-all font-bold text-gray-700 active:bg-blue-100 shadow-sm text-sm md:text-base flex items-center gap-3 group"
                                    >
                                        <span class="w-8 h-8 rounded-xl bg-blue-100 group-hover:bg-blue-200 text-blue-600 flex items-center justify-center font-black transition text-sm">${index + 1}</span>
                                        <span class="flex-1">${option}</span>
                                    </button>
                                `;
                            }).join('')}
                        </div>
                    `;
                } else {
                    // 단답형 렌더링
                    interactionHtml = `
                        <div class="flex flex-col space-y-4 mt-2">
                            <input 
                                id="short-answer-input"
                                type="text" 
                                value="${state.userInput}"
                                oninput="state.userInput = this.value"
                                onkeydown="if(event.key === 'Enter') submitAnswer()"
                                placeholder="정답을 톡톡! 입력해 주세요"
                                class="w-full p-4 border-2 border-blue-100 rounded-2xl focus:outline-none focus:border-blue-400 text-center font-bold text-lg text-gray-800 placeholder-gray-400 shadow-inner"
                                autofocus
                            />
                            <div class="flex gap-3">
                                <button 
                                    onclick="submitAnswer()"
                                    class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-extrabold py-4 rounded-2xl shadow-md transition active:scale-95 text-lg kids-font tracking-wide"
                                >
                                    정답 완료 ✏️
                                </button>
                                <button 
                                    onclick="showHintPopup()"
                                    class="px-5 bg-amber-100 hover:bg-amber-200 text-amber-800 font-extrabold py-4 rounded-2xl transition active:scale-95 flex items-center justify-center gap-1.5"
                                    title="힌트 보기"
                                >
                                    <span class="text-xl">💡</span>
                                    <span class="kids-font text-lg">힌트</span>
                                </button>
                            </div>
                        </div>
                    `;
                }
            } else {
                // feedback state
                const isCorrect = state.feedback.isCorrect;
                interactionHtml = `
                    <div class="text-center p-6 rounded-2xl ${isCorrect ? 'bg-emerald-50 border border-emerald-200' : 'bg-rose-50 border border-rose-200'} fade-in">
                        <div class="text-5xl mb-2">${isCorrect ? '⭕' : '❌'}</div>
                        <h4 class="text-lg font-extrabold ${isCorrect ? 'text-emerald-800' : 'text-rose-800'} mb-1">
                            ${isCorrect ? '정답입니다!' : '오답입니다'}
                        </h4>
                        <p class="text-gray-700 text-sm md:text-base font-semibold mb-6">
                            ${state.feedback.message}
                        </p>
                        <button 
                            id="next-btn"
                            onclick="nextQuestion()"
                            class="w-full bg-slate-800 hover:bg-slate-900 text-white font-extrabold py-4 rounded-2xl shadow-md transition active:scale-95 text-lg kids-font tracking-wide"
                        >
                            ${state.currentIndex < state.questions.length - 1 ? '다음 말씀으로 이동하기 ➡️' : '최종 골든벨 결과 보기 🏆'}
                        </button>
                    </div>
                `;
            }

            container.innerHTML = `
                <div class="w-full space-y-4 slide-up">
                    <!-- Progress Section -->
                    <div class="space-y-2">
                        <div class="flex justify-between items-center px-1">
                            <span class="bg-white/80 backdrop-blur-sm px-4 py-1.5 rounded-full text-xs font-black text-blue-800 shadow-sm border border-blue-100">
                                📖 문제 ${state.currentIndex + 1} / ${state.questions.length}
                            </span>
                            <span class="bg-amber-300 px-4 py-1.5 rounded-full text-xs font-black text-blue-900 shadow-sm">
                                현재 점수: ${state.score}점
                            </span>
                        </div>
                        <div class="w-full bg-blue-900/10 rounded-full h-3.5 shadow-inner p-0.5 overflow-hidden border border-white/60">
                            <div 
                                class="bg-gradient-to-r from-blue-500 to-indigo-600 h-2 rounded-full transition-all duration-300" 
                                style="width: ${progressPercent}%"
                            ></div>
                        </div>
                    </div>

                    <!-- Question Card Container -->
                    <div class="bg-white rounded-3xl shadow-xl p-6 md:p-8 border-b-8 border-blue-200/60 min-h-[340px] flex flex-col justify-between">
                        <div>
                            <!-- Header tags -->
                            <div class="flex justify-between items-center mb-4">
                                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-extrabold ${currentQ.type === 'choice' ? 'bg-purple-100 text-purple-800' : 'bg-sky-100 text-sky-800'}">
                                    ${currentQ.type === 'choice' ? '📝 객관식' : '✏️ 주관식 단답형'}
                                </span>
                                ${state.gameState === 'playing' && currentQ.type === 'choice' ? `
                                    <button onclick="showHintPopup()" class="text-xs text-amber-600 hover:text-amber-700 font-extrabold flex items-center gap-1 bg-amber-50 px-2.5 py-1 rounded-lg">
                                        💡 힌트 보기
                                    </button>
                                ` : ''}
                            </div>

                            <!-- Question sentence -->
                            <h2 class="text-xl md:text-2xl font-black text-gray-800 leading-snug mb-6">
                                ${currentQ.q}
                            </h2>
                        </div>

                        <!-- Response input area -->
                        <div class="mt-auto">
                            ${interactionHtml}
                        </div>
                    </div>
                </div>
            `;

            // Focus management: automatically focuses text input if in play state for short answers
            if (state.gameState === 'playing' && currentQ.type === 'short') {
                const textInput = document.getElementById('short-answer-input');
                if (textInput) textInput.focus();
            }

            // Focus management for buttons in feedback screen
            if (state.gameState === 'feedback') {
                const nextBtn = document.getElementById('next-btn');
                if (nextBtn) nextBtn.focus();
            }
        }

        // Initialize application on load
        window.onload = function() {
            initApp();
        };
    </script>
</body>
</html>
